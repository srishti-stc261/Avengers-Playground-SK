<style>
    .image-section{
        width: 100%;
        max-width: 400px;

    }
    .image-setion img{
        width: 100%;
        height: auto;
        object-fit: cover;
    }
</style>


{% if section.settings.heading %}
    <h2>{{section.settings.heading}}</h2>
    {%endif%}

<div class="image-section">
    {% if section.settings.image %}
      <img  src="{{ section.settings.image | image_url }}""
      loading="lazy">
        {%endif%}

    <div class="buttons">
       {% if section.settings.wa_button != blank %}
        <a href="{{section.settings.wa_button_link}}">{{section.settings.wa_button}}</a>
        {% endif %}
    </div>
</div>



{% schema  %} 
{
    "name":"Amrit-section",
    "settings": [
        {
            "type":"text",
            "id":"heading",
            "label": "Heading of the banner"
        },
        {
            "type":"image_picker",
             "id":"image",
             "label":"Image"
        },
        {
            "type":"text",
            "id":"wa_button",
            "label":"Button"
        },
        {
            "type":"url",
            "id":"wa_button_link",
            "label":"Button link"
        },
        {
            "type":"text",
            "id":"button_2",
            "label": "Button click"

        },
        {
            "type": "url",
            "id":"button_2_link",
             "label": "Button link"
        }
    ],
    "presets":[
        {
            "name":"Amrit Section"
        }
    ]
}
{% endschema %}