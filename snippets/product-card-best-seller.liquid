//not using this file
{% comment %}
snippets/product-card-best-seller.liquid
Renders a single product tile. Expects local variable 'product' passed in.
{% endcomment %}

<div class="ps-card" data-product-id="{{ product.id }}">
  <div class="ps-card-media">
    <a href="{{ product.url }}" class="ps-image-link">
      {% if product.images.size > 0 %}
        <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" loading="lazy" />
      {% else %}
        <div class="ps-placeholder">No image</div>
      {% endif %}
    </a>

    <!-- ribbon badge -->
    <div class="ps-ribbon">Bestseller</div>

    <!-- small color/variant chips (example) -->
    {% if product.options_with_values.size > 0 %}
      <div class="ps-chips">
        {% for variant in product.variants | slice: 0, 1 %}
          {% if variant.available %}
            <span class="chip">{{ variant.position }}</span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <!-- heart (wishlist) -->
    <button class="ps-heart" type="button" aria-label="Save to wishlist" data-product-handle="{{ product.handle }}">
      <svg width="18" height="18" viewBox="0 0 24 24"><path d="M12 21s-7-4.35-9-6.9C-..."/></svg>
    </button>
  </div>

  <div class="ps-card-body">
    <div class="ps-sku">#{{ product.handle | slice: 0, 6 }}</div>
    <h3 class="ps-title"><a href="{{ product.url }}">{{ product.title | truncate: 60 }}</a></h3>
    <div class="ps-price">
      {% if product.price_varies %}
        <span class="from">From</span>
      {% endif %}
      <span class="money">{{ product.price | money }}</span>
    </div>

    <form method="post" action="/cart/add" class="ps-addtocart">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="btn-add">ADD TO BAG</button>
    </form>
  </div>
</div>
